# WiFi credentials. Copy this file to .env and set your values.
# .env is gitignored and will not be committed.
# Same keys can be used for harbor-breeze-fan (copy .env to that project).

WIFI_SSID=your_wifi_ssid
WIFI_PASS=your_wifi_password

# IR receiver (GPIO 10). Set to 0 on transmit-only boards (no KY-022).
# Read at build time by scripts/pio_env_flags.py → -DIR_RECV_ENABLED=…
IR_RECV_ENABLED=1

# How many times to fire each IR send (1–20). Applies to saved-code Send
# (web UI / BLE) and is the default when HTTP/WS omit ?repeat=.
IR_SEND_REPEAT=1
